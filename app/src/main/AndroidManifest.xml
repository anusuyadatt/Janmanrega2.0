<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_GPS" />
    <uses-permission android:name="android.permission.ACCESS_ASSISTED_GPS" />
    <uses-permission android:name="android.permission.ACCESS_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="false" />

    <application
        android:allowBackup="false"
        android:debuggable="false"
        android:exported="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/AppTheme3"
        tools:ignore="GoogleAppIndexingWarning,HardcodedDebugMode"
        tools:replace="android:allowBackup"
        tools:targetApi="n">
        <activity
            android:name=".UploadWorksitePhoto"
            android:exported="false"
           />
        <activity
            android:name=".ViewComplaintSection"
            android:exported="false" />
        <activity
            android:name=".JobCardHolderActivity"
            android:exported="false"
            android:theme="@style/AppTheme1" />
        <activity
            android:name=".ViewSearchedAssetsActivity"
            android:exported="false" />
        <activity
            android:name=".ViewComplaintStatusActivity"
            android:exported="false" />
        <activity
            android:name=".WorkerQueryNewActivity"
            android:exported="false"
            android:theme="@style/AppThemeParent" />
        <activity
            android:name=".SearchByJobCardActivity"
            android:exported="false" />
        <activity
            android:name=".GiveFeedbackWorkerReportActivity"
            android:exported="false" />
        <activity
            android:name=".NearByAssetsMapActivity"
            android:exported="false" />
        <activity
            android:name=".SendFeedBackActivity"
            android:exported="false"
            android:theme="@style/AppThemeParent" />
        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <service android:name=".common.GlobalLocationService" />
    </application>

</manifest>