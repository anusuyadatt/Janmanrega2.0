<resources>

    <!--
        Base application theme, dependent on API level. This theme is replaced
        by AppBaseTheme from res/values-vXX/styles.xml on newer devices.
    -->
<!--    <style name="AppBaseTheme" parent="android:Theme.Light">-->
<!--        &lt;!&ndash;-->
<!--            Theme customizations available in newer API levels can go in-->
<!--            res/values-vXX/styles.xml, while customizations related to-->
<!--            backward-compatibility can go here.-->
<!--        &ndash;&gt;-->
<!--    </style>-->

    <style name="AppBaseTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorControlNormal">@color/white</item>
        <!--
            Theme customizations available in newer API levels can go in
            res/values-vXX/styles.xml, while customizations related to
            backward-compatibility can go here.
        -->
    </style>

    <!-- Application theme. -->
    <style name="AppTheme" parent="AppBaseTheme">
        <!-- All customizations that are NOT specific to a particular API-level can go here. -->
    </style>



    <style name="AppTheme1" parent="Theme.MaterialComponents.Light">
        <!-- All customizations that are NOT specific to a particular API-level can go here. -->
    </style>


    <style name="AppTheme2" parent="Theme.MaterialComponents.DayNight">
        <!-- All customizations that are NOT specific to a particular API-level can go here. -->
    </style>
    <style name="AppTheme3" parent="Theme.AppCompat.Light">
        <!-- All customizations that are NOT specific to a particular API-level can go here. -->
    </style>
      <style name="AppTheme4" parent="Theme.MaterialComponents.Light.NoActionBar">
           <!-- All customizations that are NOT specific to a particular API-level can go here. -->
       </style>
    <style name="TabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">@dimen/tab_text</item>
        <item name="android:textStyle">bold</item>
        <item name="textAllCaps">false</item>
        <item name="android:textAllCaps">false</item>

    </style>
    <style name="style_text_input_layout" parent="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="hintTextColor">@color/colorPrimary</item>
        <item name="helperTextEnabled">true</item>
        <item name="helperTextTextColor">@color/colorAccent</item>
        <item name="startIconTint">@color/colorAccent</item>
        <item name="errorEnabled">true</item>
        <item name="boxStrokeColor">@color/colorPrimaryDark</item>
    </style>
    <style name="buttonBlue" parent="@android:style/Widget.Button">
        <item name="android:textAppearance">?android:attr/textAppearanceMedium</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:layout_width">250dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/button_main</item>
        <item name="android:textAllCaps">true</item>
    </style>
    <style name="buttonLightBlue" parent="@android:style/Widget.Button">
        <item name="android:textAppearance">?android:attr/textAppearanceMedium</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:layout_width">250dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/button_secondary</item>
        <item name="android:textAllCaps">true</item>
    </style>
    <style name="AppThemeParent" parent="Theme.MaterialComponents.Light">
        <item name="colorPrimary">@color/list_background_pressed</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>
</resources>
