            <TextView
                android:id="@+id/tvCatDHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/work_category_d"
                android:layout_marginLeft="10dp"
                android:layout_weight="0.9"
                android:textSize="15sp"
                android:textColor="@color/grey"
                android:textStyle="bold"
                android:layout_gravity="center_vertical"
                android:gravity="center_vertical"
                ></TextView>

            <ImageView
                android:id="@+id/imgCatDHeader"
                android:layout_width="25dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical|right"
                android:gravity="center_vertical"
                android:background="@drawable/ic_baseline24_hide_data"
                android:layout_weight="0.1"
                android:layout_marginTop="10dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearCatDContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="2dp"
            android:layout_marginRight="2dp"
            android:visibility="gone">

            <RadioGroup
                android:id="@+id/rgCatDContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp"
                android:weightSum="3">

                <RadioButton
                    android:id="@+id/rbNrCatDContent"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/radio_selector"
