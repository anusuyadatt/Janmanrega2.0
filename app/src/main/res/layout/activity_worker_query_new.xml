                <LinearLayout
                    android:id="@+id/linearSubSection"
                    android:visibility="visible"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:background="#fff"
                    android:orientation="vertical"
                    >
                    <TextView
                        android:id="@+id/tvWorkerName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/worker_name"
                        android:textColor="@color/blue"
                        android:layout_marginTop="10dp"
                        android:layout_marginLeft="10dp"
                        android:textSize="15sp"
                        />
                    <LinearLayout
                        android:id="@+id/llWorkerName"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/et_style"
                        android:padding="5dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:layout_marginTop="5dp">
                        <Spinner
                            android:id="@+id/spinnerWorker"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:prompt="@string/worker_name" />

                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvComplaintCategory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/complaint_category"
                        android:textColor="@color/blue"
                        android:layout_marginTop="10dp"
                        android:layout_marginLeft="10dp"
                        android:textSize="15sp"
                        />
                    <LinearLayout
                        android:id="@+id/llComplaintCategory"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/et_style"
                        android:padding="5dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:layout_marginTop="5dp">
                        <Spinner
                            android:id="@+id/spinnerComplaintCategory"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:prompt="@string/complaint_category" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvComplaintSubCategory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/complaint_sub_category"
                        android:textColor="@color/blue"
                        android:layout_marginTop="10dp"
                        android:layout_marginLeft="10dp"
                        android:textSize="15sp"
                        android:visibility="gone"
                        />
                    <LinearLayout
                        android:id="@+id/llComplaintSubCategory"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/et_style"
                        android:padding="5dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:layout_marginTop="5dp"
                        android:visibility="gone">
                        <Spinner
                            android:id="@+id/spinnerComplaintSubCategory"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:prompt="@string/complaint_sub_category" />

                    </LinearLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id = "@+id/etComplaintDescLayout"
                        android:layout_width = "match_parent"
                        android:layout_height = "wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:hint = "@string/complaint_description"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"


                        >
                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width = "match_parent"
                            android:layout_height = "wrap_content"
                            android:id = "@+id/etComplaintDesc"

                            android:inputType="textMultiLine"
                            android:overScrollMode="always"
                            android:scrollbarStyle="insideInset"
                            android:scrollbars="vertical"
                            />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id = "@+id/etNameLayout"
                        android:layout_width = "match_parent"
                        android:layout_height = "wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:hint = "@string/your_name"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        >
                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width = "match_parent"
                            android:layout_height = "wrap_content"
                            android:id = "@+id/etName"
                            android:inputType = "textPersonName"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_below="@+id/etNameLayout"
                        android:id="@+id/etMobileLayout"
                        android:layout_width = "match_parent"
                        android:layout_height = "wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:hint = "@string/mobile_number"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        >
                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width = "match_parent"
                            android:layout_height = "wrap_content"
                            android:id = "@+id/etMobile"
                            android:maxLength="10"
                            android:inputType = "number"
                            />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="10dp"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:orientation="horizontal"
                        android:layout_below="@+id/etMobileLayout"
                        android:weightSum="2"
                        >
                        <android.widget.Button
                            android:id="@+id/btnGetOtp"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="@string/get_otp"
                            android:textColor="@color/white"
                            android:layout_marginTop = "6dp"
                            android:layout_marginRight="2dp"
                            android:background="@color/green_color"/>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id ="@+id/etOtpLayout"
                            android:layout_width = "match_parent"
                            android:layout_height = "match_parent"
                            android:layout_marginLeft="2dp"
                            android:layout_weight="1"
                            android:hint = "OTP"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            >
                            <com.google.android.material.textfield.TextInputEditText
                                android:layout_width = "match_parent"
                                android:layout_height = "match_parent"
                                android:id = "@+id/etOtp"
                                android:maxLength="6"
                                android:inputType="numberPassword"/>
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                    <android.widget.Button
                        android:id="@+id/btnSubmit"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:background="@color/list_background_pressed"
                        android:gravity="center"
                        android:textColor="@android:color/white"
                        android:layout_marginTop="10dp"
                        android:text="@string/submit"

                        />
                </LinearLayout>

            </LinearLayout>
            <!--  Worker's Query Section -->


        </LinearLayout>
    </ScrollView>

</RelativeLayout>